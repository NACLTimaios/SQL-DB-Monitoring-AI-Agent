# ===========================
# CRITICAL SECURITY VARIABLES
# ===========================
# These MUST be set before deployment. Never use defaults in production.

# JWT Secret Key - used to sign authentication tokens
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secure-random-key-here

# Database credentials
AGENT_DB_PASSWORD=secure-password-for-agent-db-user
MONITORED_DB_PASSWORD=secure-password-for-monitoring-user

# ===========================
# CORS Configuration
# ===========================
# Comma-separated list of allowed origins for CORS requests
# Example: https://sqlagent.example.com,https://dashboard.example.com
CORS_ORIGINS=http://localhost:3000

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1

# ===========================
# LLM Provider Configuration
# ===========================
# Choose one of: anthropic, google, openai, prisma
# Set LLM_PROVIDER and LLM_MODEL environment variables

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Gemini
GOOGLE_API_KEY=your-google-api-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Prisma AI (or any OpenAI-compatible endpoint)
PRISMA_API_KEY=your-prisma-api-key
PRISMA_API_URL=https://api.prisma.ai  # or your self-hosted instance URL

# ===========================
# Security: Palo Alto Prisma AIRS (Optional)
# ===========================
# Prisma AIRS scans prompts/responses for injection attacks, jailbreaks, data leakage
# Get API key from Palo Alto Networks (requires enterprise contract)
# Regional: API key locked to region (americas, eu-germany, india, singapore)
PRISMA_AIRS_API_KEY=your-prisma-airs-api-key
PRISMA_AIRS_REGION=americas

# ===========================
# Model Selection
# ===========================
# Set these to choose which model to use
# Examples:
#   LLM_PROVIDER=anthropic    LLM_MODEL=claude-3-5-sonnet-20241022
#   LLM_PROVIDER=google       LLM_MODEL=gemini-2.0-flash
#   LLM_PROVIDER=google       LLM_MODEL=gemini-1.5-pro
#   LLM_PROVIDER=google       LLM_MODEL=gemini-1.5-flash
#   LLM_PROVIDER=openai       LLM_MODEL=gpt-4-turbo
#   LLM_PROVIDER=openai       LLM_MODEL=gpt-3.5-turbo
#   LLM_PROVIDER=prisma       LLM_MODEL=prisma-7b

# Default models if not specified:
#   Anthropic: claude-3-5-sonnet-20241022
#   Google: gemini-1.5-pro
#   OpenAI: gpt-4-turbo
#   Prisma: prisma-7b

# ===========================
# Application Configuration
# ===========================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Token expiry in minutes (default: 30)
# ACCESS_TOKEN_EXPIRE_MINUTES=30
