# Environment variables for SQL Agent

# JWT secret key for token signing (set this in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=<generate-strong-random-key-for-production>

# Anthropic API key for chatbot integration
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# Optional: Override default dashboard login credentials (defined in api/auth.py)
# DASHBOARD_USERNAME=agentadmin
# DASHBOARD_PASSWORD_HASH=<set-bcrypt-or-argon2-hash>
